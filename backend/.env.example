# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# JWT Configuration
JWT_SECRET=your_random_secret_key_here_use_at_least_32_characters
SESSION_SECRET=your_session_secret_key_here_use_at_least_32_characters_differs_from_jwt
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate limiting
DAILY_ANALYSIS_LIMIT=5

# Application URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Optional: Gemini for POST /explain-concept (key concepts). Uses a retrieved snippet only; falls back to local NLP if disabled or on error.
# GOOGLE_API_KEY=your_google_ai_studio_key
# USE_GEMINI_CONCEPT_EXPLAIN=true
# GEMINI_MODEL=gemini-2.5-flash

# Study assistant chat (POST /chat/notes). Requires GOOGLE_API_KEY. Set false to disable.
# USE_NOTES_CHAT=true

# Hugging Face (slow networks): optional; main.py also defaults download/etag timeouts before imports.
# HF_HUB_DOWNLOAD_TIMEOUT=120
# HF_HUB_ETAG_TIMEOUT=60
